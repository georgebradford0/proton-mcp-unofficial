# Copy to .env (or set these in your MCP client config) and fill in.
# Values come from the Proton Bridge desktop app.

# Your Proton email address (the Bridge account username).
PROTON_BRIDGE_USERNAME=you@proton.me

# The BRIDGE-SPECIFIC password shown in the Bridge app
# (Settings → your account → "Password"). NOT your normal Proton login.
PROTON_BRIDGE_PASSWORD=bridge-app-password

# Optional — defaults shown. Override only if Bridge reports different ports.
# PROTON_BRIDGE_HOST=127.0.0.1
# PROTON_BRIDGE_IMAP_PORT=1143
# PROTON_BRIDGE_SMTP_PORT=1025

# Optional — default From address used by send_email when no `from` is given.
# Falls back to the legacy PROTON_BRIDGE_FROM, then to PROTON_BRIDGE_USERNAME.
# PROTON_DEFAULT_ADDRESS=you@proton.me

# Optional — the account addresses/aliases you can send from, comma-separated.
# This is the authoritative list the list_addresses tool returns.
# PROTON_BRIDGE_ADDRESSES=you@proton.me,you.alias@proton.me,you@customdomain.com

# Optional — Bridge uses a self-signed cert, so TLS verification is OFF by
# default. Set to true only after installing the Bridge CA certificate.
# PROTON_BRIDGE_TLS_REJECT_UNAUTHORIZED=false
